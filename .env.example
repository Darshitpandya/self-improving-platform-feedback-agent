# Required
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_REPO=your-org/your-repo

# Required for real Bedrock mode (optional if using --dry-run)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=ap-southeast-2
BEDROCK_MODEL_ID=au.anthropic.claude-sonnet-4-6

# Optional: pgvector pattern memory (requires docker-compose up)
# PGVECTOR_PASSWORD=your_secure_password_here
# DATABASE_URL=postgresql://agent:your_secure_password_here@localhost:5432/feedback_agent
